+        dept: 'Content',
+        type: 'Article',
+        body: 'Update body',
+        priority: 'Normal',
+        entry_date: '2026-04-07',
+        created_by: 'content-admin',
+        tags: [],
+        author_name: 'Content Admin',
+        academic_year: '2025-2026',
+        student_count: null,
+        external_link: '',
