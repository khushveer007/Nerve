APP_BASE_URL=http://127.0.0.1:8080
API_PORT=3001
VITE_API_BASE_URL=/api
VITE_ASSISTANT_ENABLED=true
COOKIE_SECURE=false
SESSION_SECRET=replace-with-a-local-session-secret
DATABASE_URL=postgres://nerve_app:replace-with-db-password@127.0.0.1:5432/nerve
POSTGRES_DB=nerve
POSTGRES_USER=nerve_app
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_DATA_DIR=./.local/postgres-data
SUPER_ADMIN_EMAIL=super@parul.ac.in
SUPER_ADMIN_PASSWORD=replace-with-local-dev-password
ASSISTANT_RAG_ENABLED=true
ASSISTANT_QUERY_RESULT_LIMIT=5
ASSISTANT_EMBEDDING_URL=
ASSISTANT_EMBEDDING_API_KEY=
ASSISTANT_EMBEDDING_API_HEADER=Authorization
ASSISTANT_EMBEDDING_AUTH_SCHEME=Bearer
ASSISTANT_EMBEDDING_MODEL=text-embedding-3-small
ASSISTANT_EMBEDDING_DIMENSIONS=1536
ASSISTANT_WORKER_POLL_MS=1000
ASSISTANT_JOB_MAX_ATTEMPTS=3
ASSISTANT_JOB_RETRY_BASE_MS=15000
ASSISTANT_JOB_STALE_LOCK_MS=60000
